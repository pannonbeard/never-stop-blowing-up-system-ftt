<form class="{{cssClass}} flexcol" autocomplete="off">
  {{!-- Sheet Header --}}
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}"/>
    <div class="header-fields">
      <h1 class="charname"><input name="name" type="text" value="{{actor.name}}" placeholder="Character Name"/></h1>
      <div class="resources">
        <div class="resource health">
          <label>Health</label>
          <span>{{healthStatus}}</span>
          <div class="resource-row flexrow flex-center">
            <button type="button" class="heal-injury resource-button">Heal</button>
            <button type="button" class="add-injury resource-button">Injury</button>
          </div>
        </div>
        <div class="resource tokens">
          <label>Turbo Tokens</label>
          <span>{{system.tokens}}</span>
          <div class="resource-row flexrow flex-center">
            <button type="button" class="gain-token resource-button">Gain</button>
          </div>
        </div>
      </div>
      {{!-- Catchphrase --}}
      <div class="form-group catchphrase">
        <label>Catchphrase</label>
        <input type="text" name="system.catchphrase" value="{{system.catchphrase}}"/>
      </div>
    </div>
  </header>

  {{!-- Sheet Body --}}
  <section class="sheet-body">
    <div class="tab character active" data-tab="character">

      {{!-- Skills Grid --}}
      <div class="skills-grid">
        <div class="skills-header flexrow">
          <h3 style="flex-grow: 20; color: white">Skills</h3>
          <div class="header-controls config-group">
            {{#if editMode}}
            <button type="button" class="reset-skills" title="Reset All Skills to d4">
              <i class="fas fa-undo"></i>
            </button>
            {{/if}}
            <button type="button" class="settings-toggle {{#if editMode}}active{{/if}}" title="Toggle Edit Mode">
              <i class="fas fa-cog"></i>
            </button>
          </div>
        </div>
        <div class="skills-container grid grid-3col {{#if editMode}}edit-mode{{/if}}">
          {{#each skills as |skill index|}}
          <div class="skill-wrapper">
            {{#if ../editMode}}
            <div class="skill-edit">
              <div class="skill-name-edit">{{skill.name}}</div>
              <div class="skill-controls">
                <button type="button" class="decrease-skill" data-skill="{{skill.key}}">-</button>
                <span class="skill-die-edit">d{{skill.dice}}</span>
                <button type="button" class="increase-skill" data-skill="{{skill.key}}">+</button>
              </div>
            </div>
            {{else}}
            <button type="button" class="skill-button roll-skill" data-skill="{{skill.key}}">
              <div class="skill-name">{{skill.name}}</div>
              <div class="skill-die">d{{skill.dice}}</div>
            </button>
            {{/if}}
          </div>
          {{/each}}
        </div>
      </div>

      {{!-- Abilities --}}
      <div class="abilities">
        <h3 style="color: white">Abilities</h3>
        <div class="ability">
          <label>Ability One</label>
          <input type="text" name="system.abilityone.name" value="{{system.abilityone.name}}" placeholder="Name"/>
          <textarea name="system.abilityone.description">{{system.abilityone.description}}</textarea>
        </div>
        <div class="ability">
          <label>Ability Two</label>
          <input type="text" name="system.abilitytwo.name" value="{{system.abilitytwo.name}}" placeholder="Name"/>
          <textarea name="system.abilitytwo.description">{{system.abilitytwo.description}}</textarea>
        </div>
        <div class="ability">
          <label>Ability Three</label>
          <input type="text" name="system.abilitythree.name" value="{{system.abilitythree.name}}" placeholder="Name"/>
          <textarea name="system.abilitythree.description">{{system.abilitythree.description}}</textarea>
        </div>
      </div>

    </div>
  </section>
</form>