<form class="{{cssClass}} flexcol" autocomplete="off">
  {{#unless editMode}}
    <div class="name-overlay hidden-small-screen" style="--text-color: {{system.nameprimarycolor}}; --text-shadow: {{system.nameshadowcolor}};">{{actor.name}}</div>
  {{/unless}}

  {{!-- Sheet Header --}}
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}"/>
    <div class="header-fields">
      <button type="button" class="settings-toggle {{#if editMode}}active{{/if}}" title="Toggle Edit Mode">
        <i class="fas fa-cog"></i>
      </button>
      {{#if editMode}}
        <h1 class="charname"><input name="name" type="text" value="{{actor.name}}" placeholder="Character Name"/></h1>        
      {{else}}
        <div class="name-overlay hidden-big-screen" style="--text-color: {{system.nameprimarycolor}}; --text-shadow: {{system.nameshadowcolor}};">{{actor.name}}</div>
      {{/if}}
      {{#if editMode}}
      <div class="resources"> 
        <div>
          <label>Name Color</label>
          <input type='color' name="system.nameprimarycolor" value="{{system.nameprimarycolor}}"/>
        </div>

        <div>
          <label>Name Shadow</label>
          <input type='color'  name="system.nameshadowcolor" value="{{system.nameshadowcolor}}"/>
        </div>
      </div>
      {{else}}
      <div class="resources">
        <div class="resource health">
          <label class="current-status">{{healthStatus}}</label>
          <div class="resource-row flexrow flex-center">
            <button type="button" class="heal-injury resource-button">Heal</button>
            <button type="button" class="add-injury resource-button">Injure</button>
          </div>
        </div>
        <div class="resource tokens">
          <label class="current-status">Turbo Tokens</label>
          <div class="resource-row flexrow flex-center">
            <span class="token-count">{{system.tokens}}</span>
            <button type="button" class="gain-token resource-button">Add</button>
          </div>
        </div>
      </div>
      {{/if}}
      {{!-- Catchphrase --}}
      <div class="form-group catchphrase">
        {{#if editMode}}
          <label>Catchphrase</label>
          <input type="text" name="system.catchphrase" value="{{system.catchphrase}}"/>
        {{else}}
          <p class="catchphrase live"><strong>Catchphrase:</strong><br />
          {{#if system.catchphrase}}{{system.catchphrase}}{{/if}}
          {{#unless system.catchphrase}}Open Edit mode to set your catchphrase.{{/unless}}
          </p>
        {{/if}}
      </div>
    </div>
  </header>

  {{!-- Sheet Body --}}
  <section class="sheet-body">
    <div class="tab character active" data-tab="character">

      {{!-- Skills Grid --}}
      <div class="skills-grid">
        <div class="skills-header flexrow">
          <h3 style="flex-grow: 20; color: white">Skills</h3>
          <div class="header-controls config-group">
            {{#if editMode}}
            <button type="button" class="reset-skills" title="Reset All Skills to d4">
              <i class="fas fa-undo"></i>
            </button>
            {{/if}}
          </div>
        </div>
        <div class="skills-container grid grid-3col {{#if editMode}}edit-mode{{/if}}">
          {{#each skills as |skill index|}}
          <div class="skill-wrapper">
            {{#if ../editMode}}
            <div class="skill-edit">
              <div class="skill-name-edit">{{skill.name}}</div>
              <div class="skill-controls">
                <button type="button" class="decrease-skill" data-skill="{{skill.key}}">-</button>
                <span class="skill-die-edit">d{{skill.dice}}</span>
                <button type="button" class="increase-skill" data-skill="{{skill.key}}">+</button>
              </div>
            </div>
            {{else}}
            <button type="button" class="skill-button roll-skill" data-skill="{{skill.key}}">
              <div class="skill-name">{{skill.name}}</div>
              <div class="skill-die">d{{skill.dice}}</div>
            </button>
            {{/if}}
          </div>
          {{/each}}
        </div>
      </div>

      {{!-- Abilities --}}
      <div class="abilities">
        <h3 style="color: white">Abilities</h3>
        <button type="button" class="add-ability ability-btn">+ Add Ability</button>
        {{#each system.abilities as |ability i|}}
          <div class="ability" data-index="{{i}}">
            <div class="ability-title">
              <span>Ability</span>
              <button type="button" class="remove-ability ability-btn">Remove</button>
            </div>
            <input type="text" name="system.abilities.{{i}}.name" value="{{ability.name}}" placeholder="Name"/>
            <textarea name="system.abilities.{{i}}.description">{{ability.description}}</textarea>
          </div>
        {{/each}}
      </div>
    </div>
  </section>
</form>